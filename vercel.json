{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/*.mjs": {
      "maxDuration": 10
    }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store"
        }
      ]
    }
  ]
}
